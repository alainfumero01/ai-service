      "title": "SAND2021-12461 Alternative Damage Standards",
      "standard_type": "quality",
      "issuing_body": "Sandia National Laboratories",
      "version_label": "2021",
      "summary": "Damage tolerance and allowable flaw-size concepts that support monitor-versus-repair decisions.",
      "document_uri": "https://www.osti.gov/servlets/purl/1825355",
      "requirements": [
        {
          "requirement_code": "SAND-MONITOR",
          "title": "Allowable flaw gate",
          "damage_codes": [
            "A1",
            "B3",
            "C5",
            "D1"
          ],
          "excerpt": "Some flaws can remain in service when size, growth risk, and structural context stay below defined tolerance thresholds.",
          "citation": "SAND2021 damage tolerance principle"
        },
        {
          "requirement_code": "SAND-ESCALATE",
          "title": "Service versus repair threshold",
          "damage_codes": [
            "A5",
            "B2",
            "C4"
          ],
          "excerpt": "When flaws exceed tolerance or threaten load paths, the decision logic shifts from monitor to immediate repair or shutdown planning.",
          "citation": "SAND2021 leave-in-service decision gate"
        }
      ]
    },
    {
      "standard_code": "STD-005",
      "title": "ASTM D5528 Mode I Interlaminar Fracture Toughness",
      "standard_type": "quality",
      "issuing_body": "ASTM International",
      "version_label": "D5528",
      "summary": "Material qualification method used to verify repair resin resistance to delamination opening loads.",
      "document_uri": "https://www.astm.org/d5528-13.html",
      "requirements": [
        {
          "requirement_code": "ASTM-D5528-QUAL",
          "title": "Mode I repair material qualification",
          "damage_codes": [
            "B1",
            "B2",
            "E1",
            "E3"
          ],
          "excerpt": "Repair systems should meet or exceed the parent laminate Mode I fracture toughness needed to avoid bondline delamination failure.",
          "citation": "ASTM D5528 qualification basis"
        }
      ]
    },
    {
      "standard_code": "STD-006",
      "title": "ASTM D6671 Mixed Mode I/II Interlaminar Fracture Toughness",
      "standard_type": "quality",
      "issuing_body": "ASTM International",
      "version_label": "D6671",
      "summary": "Mixed-mode fracture toughness method used where repaired laminates experience peel and shear together.",
      "document_uri": "https://www.astm.org/d6671_d6671m-13.html",
      "requirements": [
        {
          "requirement_code": "ASTM-D6671-QUAL",
          "title": "Mixed-mode repair material qualification",
          "damage_codes": [
            "C5",
            "E1",
            "E3"
          ],
          "excerpt": "Mixed-mode fracture performance matters when repaired laminates see combined peel and shear loads during blade bending and torsion.",
          "citation": "ASTM D6671 qualification basis"
        }
      ]
    },
    {
      "standard_code": "STD-007",
      "title": "FAA AC 43-214A Composite and Bonded Structure Repairs",
      "standard_type": "regulatory",
      "issuing_body": "Federal Aviation Administration",
      "version_label": "AC 43-214A",
      "summary": "Public composite repair procedure reference used for scarf ratios, cure control, and post-repair inspection logic.",
      "document_uri": "https://www.faa.gov/documentLibrary/media/Advisory_Circular/AC_43-214A.pdf",
      "requirements": [
        {
          "requirement_code": "FAA-SCARF",
          "title": "Structural scarf taper",
          "damage_codes": [
            "B2",
            "B4",
            "B5",
            "E4",
            "E5"
          ],
          "excerpt": "Structural scarf repairs commonly use taper ratios in the twenty-to-one to fifty-to-one range depending on material and depth.",
          "citation": "FAA AC 43-214A scarf ratio guidance"
        },
        {
          "requirement_code": "FAA-CURE",
          "title": "Cure verification",
          "damage_codes": [
            "B1",
            "B2",
            "E1",
            "E3"
          ],
          "excerpt": "Composite repairs need documented cure controls and verification such as hardness checks before the repair is released.",
          "citation": "FAA AC 43-214A cure verification"
        },
        {
          "requirement_code": "FAA-INSPECT",
          "title": "Inspection after repair",
          "damage_codes": [
            "B1",
            "B2",
            "B6",
            "C5",
            "D5"
          ],
          "excerpt": "Visual inspection, tap testing, and UT are used as closeout checks based on whether the repair is cosmetic, non-structural, or structural.",
          "citation": "FAA AC 43-214A post-repair inspection"
        },
        {
          "requirement_code": "FAA-DAMAGE-CLASS",
          "title": "Damage class routing",
          "damage_codes": [
            "A6",
            "B6",
            "E4"
          ],
          "excerpt": "Composite damage should be classified as cosmetic, non-structural, structural, or primary-structure before repair scope is selected.",
          "citation": "FAA AC 43-214A repair class framework"
        }
      ]
    }
